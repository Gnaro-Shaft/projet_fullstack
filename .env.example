# Qdrant Cloud (ou http://localhost:6333 en développement local)
QDRANT_API_KEY=your-qdrant-api-key-here
QDRANT_URL=https://your-qdrant-instance-url-here
QDRANT_COLLECTION=documents

# Mistral API
MISTRAL_API_KEY=your-mistral-api-key-here
MISTRAL_URL=https://api.mistral.ai/v1
MISTRAL_MODEL=mistral-small-latest
MISTRAL_EMBEDDING_MODEL=mistral-embed-2312
MISTRAL_MAX_RETRIES=5



FASTAPI_PORT=8000
BACKEND_URL=http://localhost:8000
ADMIN_API_KEY=change-me-for-document-deletion

SPACY_MODEL=fr_core_news_sm
PII_ENABLE_NER=true
